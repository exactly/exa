+- (void)emitTrace:(NSString *)event details:(NSDictionary *)details
+{
+    NSMutableDictionary *body = [NSMutableDictionary new];
+    body[@"event"] = event;
+    body[@"timestamp"] = @((long long)([[NSDate date] timeIntervalSince1970] * 1000));
+    if (details.count > 0) [body addEntriesFromDictionary:details];
+    NSLog(@"ApplePayTrace %@", body);
+    if (self.hasListeners) {
+        dispatch_async(dispatch_get_main_queue(), ^{
+            [self sendEventWithName:APPLE_PAY_TRACE_EVENT body:body];
+        });
+    }
 }
 
