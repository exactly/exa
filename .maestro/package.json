{
  "name": "@exactly/e2e",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "prepare": "nx build e2e",
    "dev": "nx dev e2e"
  },
  "devDependencies": {
    "@exactly/common": "workspace:^0.0.9",
    "@noble/curves": "^2.0.1",
    "@noble/hashes": "^2.0.1",
    "esbuild": "^0.27.0",
    "fast-text-encoding": "^1.0.6",
    "typescript": "^5.8.3",
    "viem": "^2.40.3"
  },
  "nx": {
    "projectType": "library",
    "targets": {
      "build": {
        "executor": "@nx/esbuild:esbuild",
        "inputs": [
          "production",
          "^production"
        ],
        "outputs": [
          "{options.outputPath}"
        ],
        "options": {
          "bundle": true,
          "thirdParty": true,
          "platform": "neutral",
          "external": [
            "isows"
          ],
          "outputPath": "dist",
          "tsConfig": ".maestro/tsconfig.json",
          "main": "src/script/setBalance.ts",
          "additionalEntryPoints": [
            "src/script/approveKYC.ts",
            "src/script/mint.ts"
          ],
          "esbuildOptions": {
            "mainFields": [
              "module",
              "main"
            ],
            "inject": [
              "src/polyfill.ts"
            ]
          }
        }
      },
      "dev": {
        "dependsOn": [
          "spotlight",
          { "projects": "@exactly/server", "target": "e2e" },
          { "projects": "@exactly/mobile", "target": "ios" }
        ],
        "executor": "@nx/esbuild:esbuild",
        "inputs": [
          "production",
          "^production"
        ],
        "outputs": [
          "{options.outputPath}"
        ],
        "options": {
          "bundle": true,
          "thirdParty": true,
          "platform": "neutral",
          "external": [
            "isows"
          ],
          "outputPath": "dist",
          "tsConfig": ".maestro/tsconfig.json",
          "main": "src/script/setBalance.ts",
          "additionalEntryPoints": [
            "src/script/approveKYC.ts",
            "src/script/mint.ts"
          ],
          "esbuildOptions": {
            "mainFields": [
              "module",
              "main"
            ],
            "inject": [
              "src/polyfill.ts"
            ]
          },
          "watch": true
        },
        "continuous": true
      },
      "spotlight": {
        "executor": "nx:run-commands",
        "options": {
          "command": "spotlight"
        },
        "continuous": true
      }
    }
  }
}
