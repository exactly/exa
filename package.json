{
  "name": "@exactly/mobile",
  "version": "1.2.5",
  "title": "Exa App",
  "shortDescription": "What finance should be today",
  "description": "A Card. A Wallet. A DeFi Protocol. All of it together.",
  "main": "./src/index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build": "EXPO_NO_TELEMETRY=1 expo export --platform web --no-minify --source-maps",
    "prepare": "nx prepare mobile",
    "prepare:generated": "mkdir -p src/generated",
    "generate:expo": "expo customize tsconfig.json",
    "generate:release": "echo \"module.exports = /** @type {const} */ ('$(git describe --tags --abbrev=7 --match '@exactly/mobile@*' | sed 's/@exactly\\///')')\" > src/generated/release.js",
    "generate:version": "echo \"module.exports = /** @type {const} */ ($(git rev-list --count HEAD))\" > src/generated/versionCode.js",
    "e2e:iphone": "maestro start-device --platform=ios --os-version=26 --device-locale=es-419",
    "e2e:android:proxy": "adb start-server && adb reverse tcp:3000 tcp:3000 && adb reverse tcp:8545 tcp:8545 && adb reverse tcp:8969 tcp:8969",
    "e2e:maestro": "maestro test .maestro/flows --include-tags=critical",
    "test": "nx test mobile",
    "test:spell": "cspell --gitignore '**' '.agents/**' '.changeset/**' '.do/**' '.eas/**' '.github/**' '.maestro/**'",
    "test:deps": "pnpm audit",
    "test:build": "EXPO_NO_TELEMETRY=1 expo export --platform web",
    "test:ts": "tsc --pretty ${GITHUB_ACTIONS:+false}",
    "test:markdown": "markdownlint '**/*.md' '**/*.mdx' '.agents/**/*.md' '.changeset/**/*.md' -i '**/node_modules/**' -i ios/Pods",
    "test:changeset": "changeset status --since origin/main"
  },
  "engines": {
    "node": "^24.14.1"
  },
  "dependencies": {
    "@aa-sdk/core": "catalog:",
    "@account-kit/infra": "catalog:",
    "@account-kit/smart-contracts": "catalog:",
    "@exactly/common": "workspace:^0.0.14",
    "@exactly/lib": "^0.1.0",
    "@exactly/server": "workspace:^0.2.90",
    "@expo/metro-runtime": "~55.0.6",
    "@farcaster/frame-sdk": "^0.1.14",
    "@farcaster/miniapp-sdk": "^0.2.3",
    "@farcaster/miniapp-wagmi-connector": "^1.1.1",
    "@intercom/intercom-react-native": "^9.8.0",
    "@intercom/messenger-js-sdk": "^0.0.18",
    "@lifi/sdk": "3.7.7",
    "@meawallet/react-native-mpp": "^2.2.2",
    "@peculiar/asn1-ecc": "^2.6.1",
    "@peculiar/asn1-schema": "^2.6.0",
    "@peculiar/webcrypto": "^1.5.0",
    "@pix.js/qrcode": "^1.1.0",
    "@react-native-async-storage/async-storage": "~2.2.0",
    "@sentry/browser": "^10.46.0",
    "@sentry/react-native": "^8.6.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@tamagui/animations-moti": "catalog:",
