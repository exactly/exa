{
  "name": "@exactly/mobile",
  "version": "1.2.12",
  "title": "Exa App",
  "shortDescription": "What finance should be today",
  "description": "A Card. A Wallet. A DeFi Protocol. All of it together.",
  "main": "./src/index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build": "EXPO_NO_TELEMETRY=1 expo export --platform web --no-minify --source-maps",
    "prepare": "nx prepare mobile",
    "prepare:generated": "mkdir -p src/generated",
    "generate:expo": "expo customize tsconfig.json",
    "generate:release": "echo \"module.exports = /** @type {const} */ ('$(git describe --tags --abbrev=7 --match '@exactly/mobile@*' | sed 's/@exactly\\///')')\" > src/generated/release.js",
    "generate:version": "echo \"module.exports = /** @type {const} */ ($(git rev-list --count HEAD))\" > src/generated/versionCode.js",
    "e2e:iphone": "maestro start-device --platform=ios --os-version=26 --device-locale=es-419",
    "e2e:android:proxy": "adb start-server && adb reverse tcp:3000 tcp:3000 && adb reverse tcp:8545 tcp:8545 && adb reverse tcp:8969 tcp:8969",
    "e2e:maestro": "maestro test .maestro/flows --include-tags=critical",
    "test": "nx test mobile",
    "test:spell": "cspell --gitignore '**' '.agents/**' '.changeset/**' '.do/**' '.eas/**' '.github/**' '.maestro/**'",
    "test:deps": "pnpm audit",
    "test:build": "EXPO_NO_TELEMETRY=1 expo export --platform web",
    "test:ts": "tsc --pretty ${GITHUB_ACTIONS:+false}",
    "test:markdown": "markdownlint '**/*.md' '**/*.mdx' '.agents/**/*.md' '.changeset/**/*.md' -i '**/node_modules/**' -i ios/Pods",
    "test:changeset": "changeset status --since origin/main"
  },
  "engines": {
    "node": "^24.16.0"
  },
  "dependencies": {
    "@aa-sdk/core": "catalog:",
    "@account-kit/infra": "catalog:",
    "@account-kit/smart-contracts": "catalog:",
    "@exactly/common": "workspace:^0.0.14",
    "@exactly/lib": "^0.1.0",
    "@exactly/server": "workspace:^0.2.98",
    "@expo/metro-runtime": "~56.0.13",
    "@farcaster/frame-sdk": "^0.2.0",
    "@farcaster/miniapp-sdk": "^0.3.0",
    "@farcaster/miniapp-wagmi-connector": "^2.0.0",
    "@intercom/intercom-react-native": "^10.2.0",
    "@intercom/messenger-js-sdk": "^0.0.19",
    "@lifi/sdk": "3.7.7",
    "@peculiar/asn1-ecc": "^2.7.0",
    "@peculiar/asn1-schema": "^2.7.0",
    "@peculiar/webcrypto": "^1.7.1",
    "@pix.js/qrcode": "^1.1.0",
    "@react-native-async-storage/async-storage": "~2.2.0",
    "@sentry/browser": "^10.56.0",
    "@sentry/react-native": "^8.13.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@tamagui/animations-reanimated": "catalog:",
    "@tamagui/config": "catalog:",
    "@tamagui/core": "catalog:",
    "@tamagui/lucide-icons-2": "catalog:",
    "@tamagui/toast": "catalog:",
    "@tanstack/query-async-storage-persister": "^5.101.0",
    "@tanstack/query-persist-client-core": "^5.101.0",
    "@tanstack/react-form": "^1.33.0",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-query-devtools": "^5.101.0",
    "@tanstack/react-query-persist-client": "^5.101.0",
    "@wagmi/core": "catalog:",
    "abitype": "^1.2.4",
    "buffer": "^6.0.3",
    "burnt": "^0.13.0",
    "comlink": "^4.4.2",
    "date-fns": "^4.4.0",
    "expo": "^56.0.9",
    "expo-application": "~56.0.3",
    "expo-asset": "~56.0.15",
    "expo-camera": "~56.0.7",
    "expo-clipboard": "~56.0.3",
    "expo-constants": "~56.0.16",
    "expo-font": "~56.0.5",
    "expo-haptics": "~56.0.3",
    "expo-image": "~56.0.9",
    "expo-insights": "~56.0.15",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.13",
    "expo-local-authentication": "~56.0.4",
    "expo-localization": "~56.0.6",
    "expo-router": "~56.2.8",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "expo-updates": "~56.0.17",
    "expo-web-browser": "~56.0.5",
    "fast-text-encoding": "^1.0.6",
    "hono": "catalog:",
    "i18n-iso-countries": "^7.14.0",
    "i18next": "catalog:",
    "moti": "^0.30.0",
    "persona": "^5.8.0",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-i18next": "^17.0.8",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.2",
    "react-native-nitro-modules": "^0.35.9",
    "react-native-onesignal": "^5.4.7",
    "react-native-passkeys": "^0.4.1",
    "react-native-persona": "^2.43.0",
    "react-native-qrcode-styled": "^0.4.0",
    "react-native-quick-crypto": "^0.7.17",
    "react-native-reanimated": "4.3.1",
    "react-native-reanimated-carousel": "^4.0.3",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.25.2",
    "react-native-size-matters": "^0.4.2",
    "react-native-svg": "15.15.4",
    "react-native-webview": "13.16.1",
    "react-native-worklets": "0.8.3",
    "react-onesignal": "^3.5.5",
    "tamagui": "catalog:",
    "title-case": "^4.3.2",
    "valibot": "catalog:",
    "viem": "catalog:",
    "wagmi": "catalog:"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@changesets/types": "^6.1.0",
    "@cspell/dict-es-es": "^3.0.8",
    "@cspell/dict-pt-br": "^2.4.2",
    "@eslint/mcp": "^0.3.6",
    "@expo/fingerprint": "^0.19.3",
    "@nx/esbuild": "22.7.5",
    "@nx/eslint": "22.7.5",
    "@nx/eslint-plugin": "22.7.5",
    "@nx/js": "22.7.5",
    "@react-native/metro-config": "^0.85.3",
    "@spotlightjs/spotlight": "^4.11.5",
    "@svgr/core": "^8.1.0",
    "@tamagui/babel-plugin": "catalog:",
    "@testing-library/dom": "^10.4.1",
    "@typescript-eslint/utils": "catalog:",
    "@types/babel__core": "^7.20.5",
    "@types/fast-text-encoding": "^1.0.3",
    "@types/node": "^25.9.2",
    "@types/qrcode": "^1.5.6",
    "@types/react": "~19.2.10",
    "@welldone-software/why-did-you-render": "^10.0.1",
    "babel-plugin-istanbul": "^8.0.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "babel-preset-expo": "~56.0.14",
    "cspell": "^10.0.1",
    "eslint": "catalog:",
    "eslint-config-universe": "^15.2.0",
    "eslint-plugin-react-native": "^5.0.0",
    "expo-build-properties": "~56.0.16",
    "expo-dev-client": "~56.0.18",
    "expo-doctor": "^1.19.9",
    "gitmojis": "^3.15.0",
    "hono-rate-limiter": "^0.5.3",
    "markdownlint-cli": "^0.48.0",
    "metro-config": "^0.83.5",
    "nx": "^22.7.5",
    "onesignal-expo-plugin": "^2.6.0",
    "prettier": "catalog:",
    "react-native-svg-transformer": "^1.5.3",
    "sharp-cli": "^5.2.0",
    "svgo": "^4.0.1",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@11.5.2",
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "enabled": true
      }
    },
    "install": {
      "exclude": [
        "@sentry/react-native",
        "typescript"
      ]
    }
  },
  "nx": {
    "projectType": "application",
    "namedInputs": {
      "default": [
        "{projectRoot}/patches/**/*",
        "{projectRoot}/src/**/*",
        "sharedGlobals",
        "!{projectRoot}/common/**/*",
        "!{projectRoot}/contracts/**/*",
        "!{projectRoot}/docs/**/*",
        "!{projectRoot}/server/**/*",
        "!{projectRoot}/src/generated/**/*",
        {
          "env": "APP_DOMAIN"
        },
        {
          "env": "EAS_BUILD_RUNNER"
        },
        {
          "env": "EXPO_PUBLIC_INTERCOM_APP_ID"
        },
        {
          "env": "NODE_ENV"
        }
      ]
    },
    "targets": {
      "test:eslint": {
        "executor": "@nx/eslint:lint",
        "options": {
          "lintFilePatterns": [
            "{projectRoot}"
          ]
        }
      },
      "prepare": {
        "dependsOn": [
          "generate:expo",
          "generate:release",
          "generate:version"
        ],
        "executor": "nx:noop"
      },
      "generate:expo": {
        "dependsOn": [
          "generate:version"
        ],
        "outputs": [
          "{projectRoot}/expo-env.d.ts"
        ]
      },
      "generate:release": {
        "dependsOn": [
          "prepare:generated",
          {
            "projects": "@exactly/common",
            "target": "git:unshallow"
          }
        ],
        "inputs": [],
        "outputs": [
          "{projectRoot}/generated/release.js"
        ],
        "cache": false
      },
      "generate:version": {
        "dependsOn": [
          "prepare:generated",
          {
            "projects": "@exactly/common",
            "target": "git:unshallow"
          }
        ],
        "inputs": [],
        "outputs": [
          "{projectRoot}/generated/versionCode.js"
        ],
        "cache": false
      },
      "start": {
        "dependsOn": [
          "prepare",
          "^prepare"
        ],
        "inputs": [
          "default",
          "^production"
        ],
        "continuous": true
      },
      "android": {
        "dependsOn": [
          "prepare",
          "^prepare"
        ],
        "inputs": [
          "default",
          "^production"
        ],
        "continuous": true
      },
      "ios": {
        "dependsOn": [
          "prepare",
          "^prepare"
        ],
        "inputs": [
          "production",
          "^production"
        ],
        "continuous": true
      },
      "web": {
        "dependsOn": [
          "prepare",
          "^prepare"
        ],
        "inputs": [
          "production",
          "^production"
        ],
        "continuous": true
      },
      "e2e:android": {
        "continuous": true,
        "dependsOn": [
          "prepare",
          "^prepare",
          {
            "projects": "@exactly/server",
            "target": "e2e"
          },
          {
            "projects": "@exactly/e2e",
            "target": "dev"
          },
          "e2e:android:proxy"
        ],
        "inputs": [
          "production",
          "^production"
        ],
        "executor": "nx:run-commands",
        "options": {
          "command": "expo run:android",
          "env": {
            "APP_DOMAIN": "localhost",
            "CHAIN_ID": "31337",
            "EXPO_PUBLIC_ENV": "e2e"
          }
        }
      },
      "e2e:ios": {
        "continuous": true,
        "dependsOn": [
          "prepare",
          "^prepare",
          {
            "projects": "@exactly/server",
            "target": "e2e"
          },
          {
            "projects": "@exactly/e2e",
            "target": "dev"
          }
        ],
        "inputs": [
          "production",
          "^production"
        ],
        "executor": "nx:run-commands",
        "options": {
          "command": "expo run:ios",
          "env": {
            "APP_DOMAIN": "localhost",
            "CHAIN_ID": "31337",
            "EXPO_PUBLIC_ENV": "e2e"
          }
        }
      },
      "e2e:ios:release": {
        "continuous": true,
        "dependsOn": [
          "prepare",
          "^prepare",
          {
            "projects": "@exactly/e2e",
            "target": "dev"
          }
        ],
        "inputs": [
          "production",
          "^production"
        ],
        "executor": "nx:run-commands",
        "options": {
          "commands": [
            "rm -rf build/Exa.app build/Exa.tar.gz",
            "pnpx eas-cli build --platform=ios --profile=e2e:local --local --output=build/Exa.tar.gz",
            "open -a Simulator",
            "tar -xzf build/Exa.tar.gz -C build",
            "xcrun simctl install booted build/Exa.app"
          ],
          "parallel": false
        }
      },
      "e2e:web": {
        "continuous": true,
        "dependsOn": [
          "prepare",
          "^prepare",
          {
            "projects": "@exactly/server",
            "target": "e2e"
          },
          {
            "projects": "@exactly/e2e",
            "target": "dev"
          }
        ],
        "inputs": [
          "production",
          "^production"
        ],
        "executor": "nx:run-commands",
        "options": {
          "command": "expo start",
          "env": {
            "APP_DOMAIN": "localhost",
            "CHAIN_ID": "31337",
            "EXPO_PUBLIC_ENV": "e2e"
          }
        }
      },
      "test": {
        "dependsOn": [
          "test:spell",
          "test:deps",
          "test:build",
          "test:ts",
          "test:markdown",
          "test:changeset",
          "test:eslint"
        ],
        "executor": "nx:noop"
      }
    }
  },
  "private": true
}
