    "expo-router": "~55.0.5",
    "expo-status-bar": "~55.0.4",
    "expo-system-ui": "~55.0.9",
    "expo-updates": "~55.0.13",
    "expo-web-browser": "~55.0.9",
    "fast-text-encoding": "^1.0.6",
    "hono": "catalog:",
    "i18n-iso-countries": "^7.14.0",
    "i18next": "catalog:",
    "moti": "^0.30.0",
    "persona": "^5.7.0",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-i18next": "^17.0.0",
    "react-native": "0.83.4",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-nitro-modules": "^0.35.2",
    "react-native-onesignal": "^5.4.1",
    "react-native-passkeys": "^0.4.0",
    "react-native-persona": "^2.34.0",
    "react-native-qrcode-styled": "^0.4.0",
    "react-native-quick-crypto": "^0.7.17",
    "react-native-reanimated": "4.2.1",
    "react-native-reanimated-carousel": "^4.0.3",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-size-matters": "^0.4.2",
    "react-native-svg": "15.15.3",
    "react-native-webview": "13.16.0",
    "react-native-worklets": "0.7.2",
    "react-onesignal": "^3.5.1",
    "tamagui": "catalog:",
    "title-case": "^4.3.2",
    "valibot": "catalog:",
    "viem": "catalog:",
    "wagmi": "catalog:"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@changesets/types": "^6.1.0",
    "@cspell/dict-es-es": "^3.0.8",
    "@cspell/dict-pt-br": "^2.4.2",
    "@eslint/mcp": "^0.3.2",
    "@expo/fingerprint": "^0.16.6",
    "@nx/esbuild": "22.6.2",
    "@nx/eslint": "22.6.2",
    "@nx/eslint-plugin": "22.6.2",
    "@nx/js": "22.6.2",
    "@spotlightjs/spotlight": "^4.11.3",
    "@svgr/core": "^8.1.0",
    "@tamagui/babel-plugin": "catalog:",
    "@types/babel__core": "^7.20.5",
    "@types/fast-text-encoding": "^1.0.3",
    "@types/node": "^25.5.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "~19.2.10",
    "@welldone-software/why-did-you-render": "^10.0.1",
    "babel-plugin-istanbul": "^7.0.1",
    "babel-plugin-module-resolver": "^5.0.3",
    "babel-preset-expo": "~55.0.8",
    "cspell": "^9.7.0",
    "eslint": "catalog:",
    "eslint-config-universe": "^15.0.3",
    "eslint-plugin-react-native": "^5.0.0",
    "expo-build-properties": "~55.0.9",
    "expo-dev-client": "~55.0.16",
    "expo-doctor": "^1.18.14",
    "gitmojis": "^3.15.0",
    "hono-rate-limiter": "^0.5.3",
    "markdownlint-cli": "^0.48.0",
    "metro-config": "^0.81.0",
    "nx": "^22.6.2",
    "onesignal-expo-plugin": "^2.4.0",
    "prettier": "^3.8.1",
    "react-native-svg-transformer": "^1.5.3",
    "sharp-cli": "^5.2.0",
    "svgo": "^4.0.1",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "@typescript-eslint/eslint-plugin": "8.58.0",
      "@typescript-eslint/parser": "8.58.0",
      "eslint-plugin-n": "17.24.0",
      "@wagmi/core": "catalog:",
      "abitype>zod": "^4.0.0",
      "comlink": "$comlink",
      "esbuild@0.18.20": "^0.25.0",
      "glob@11.0.3": "^11.1.0",
      "lodash-es@4": "^4.18.0",
      "picomatch@4": "^4.0.4",
      "postcss@8": "^8.5.10",
      "tar": "^7.5.11",
      "typescript@5": "catalog:",
      "unicorn-magic@0.3.0": "^0.2.0",
      "yauzl": "^3.2.1",
      "@anthropic-ai/claude-code": "npm:@favware/skip-dependency@1.2.2",
      "@bigmi/core": "npm:@favware/skip-dependency@1.2.2",
      "@gnosis.pm/safe-contracts": "npm:@favware/skip-dependency@1.2.2",
      "@mysten/sui": "npm:@favware/skip-dependency@1.2.2",
      "@mysten/wallet-standard": "npm:@favware/skip-dependency@1.2.2",
      "@nomiclabs/hardhat-etherscan": "npm:@favware/skip-dependency@1.2.2",
      "@solana/wallet-adapter-base": "npm:@favware/skip-dependency@1.2.2",
      "@solana/web3.js": "npm:@favware/skip-dependency@1.2.2",
      "@thehubbleproject/bls": "npm:@favware/skip-dependency@1.2.2",
      "@typechain/hardhat": "npm:@favware/skip-dependency@1.2.2",
      "@types/mocha": "npm:@favware/skip-dependency@1.2.2",
      "@wagmi/connectors": "npm:@favware/skip-dependency@1.2.2",
      "bech32": "npm:@favware/skip-dependency@1.2.2",
      "bs58": "npm:@favware/skip-dependency@1.2.2",
      "bitcoinjs-lib": "npm:@favware/skip-dependency@1.2.2",
      "ethereumjs-util": "npm:@favware/skip-dependency@1.2.2",
      "ethereumjs-wallet": "npm:@favware/skip-dependency@1.2.2",
      "hardhat-deploy": "npm:@favware/skip-dependency@1.2.2",
      "hardhat-deploy-ethers": "npm:@favware/skip-dependency@1.2.2",
      "solidity-coverage": "npm:@favware/skip-dependency@1.2.2"
    },
    "patchedDependencies": {
      "@lifi/sdk": "patches/@lifi__sdk.patch",
      "@meawallet/react-native-mpp": "patches/@meawallet__react-native-mpp.patch",
      "embedded-postgres": "patches/embedded-postgres.patch",
      "eslint-config-universe": "patches/eslint-config-universe.patch"
    },
    "updateConfig": {
      "ignoreDependencies": [
        "@eslint/js",
        "@expo/fingerprint",
        "@expo/metro-runtime",
        "@hono/valibot-validator",
        "@lifi/sdk",
        "@openzeppelin/contracts-v4",
        "@openzeppelin/contracts-upgradeable-v4",
        "@react-native-async-storage/async-storage",
        "@types/react",
        "account-abstraction",
        "babel-preset-expo",
        "eslint",
        "expo-asset",
        "expo-build-properties",
        "expo-camera",
        "expo-clipboard",
        "expo-dev-client",
        "expo-font",
        "expo-image",
        "expo-insights",
        "expo-linear-gradient",
        "expo-linking",
        "expo-router",
        "expo-status-bar",
        "expo-system-ui",
        "expo-updates",
        "expo-web-browser",
        "hono-openapi",
        "metro-config",
        "react",
        "react-dom",
        "react-native",
        "react-native-gesture-handler",
        "react-native-quick-crypto",
        "react-native-reanimated",
        "react-native-safe-area-context",
        "react-native-screens",
        "react-native-svg",
        "react-native-worklets",
        "typescript"
      ]
    },
    "neverBuiltDependencies": [],
    "peerDependencyRules": {
      "allowedVersions": {
        "@hono/mcp>hono-rate-limiter": "0.5",
        "abitype>zod": "3",
        "hono-openapi>zod": "4",
        "rollup-plugin-import-trace>vite": "8"
      }
    },
    "auditConfig": {
      "ignoreGhsas": [
        "GHSA-w5hq-g745-h8pq",
        "GHSA-848j-6mx2-7j84"
      ]
    }
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "enabled": true
      }
    },
    "install": {
      "exclude": [
        "@sentry/react-native"
      ]
    }
  },
  "nx": {
    "projectType": "application",
    "namedInputs": {
      "default": [
        "{projectRoot}/patches/**/*",
        "{projectRoot}/src/**/*",
        "sharedGlobals",
        "!{projectRoot}/common/**/*",
        "!{projectRoot}/contracts/**/*",
        "!{projectRoot}/docs/**/*",
        "!{projectRoot}/server/**/*",
        "!{projectRoot}/src/generated/**/*",
        {
          "env": "APP_DOMAIN"
        },
        {
          "env": "EAS_BUILD_RUNNER"
        },
        {
          "env": "EXPO_PUBLIC_INTERCOM_APP_ID"
        },
        {
          "env": "NODE_ENV"
        }
      ]
    },
    "targets": {
      "test:eslint": {
        "executor": "@nx/eslint:lint",
        "options": {
          "lintFilePatterns": [
            "{projectRoot}"
          ]
        }
      },
      "prepare": {
        "dependsOn": [
          "generate:expo",
          "generate:release",
          "generate:version"
        ],
        "executor": "nx:noop"
      },
      "generate:expo": {
        "dependsOn": [
          "generate:version"
        ],
        "outputs": [
          "{projectRoot}/expo-env.d.ts"
        ]
      },
      "generate:release": {
        "dependsOn": [
          "prepare:generated",
          {
            "projects": "@exactly/common",
            "target": "git:unshallow"
          }
        ],
        "inputs": [],
        "outputs": [
          "{projectRoot}/generated/release.js"
        ],
        "cache": false
      },
      "generate:version": {
        "dependsOn": [
          "prepare:generated",
          {
            "projects": "@exactly/common",
            "target": "git:unshallow"
          }
        ],
        "inputs": [],
        "outputs": [
          "{projectRoot}/generated/versionCode.js"
        ],
        "cache": false
      },
      "start": {
        "dependsOn": [
          "prepare",
          "^prepare"
        ],
        "inputs": [
          "default",
          "^production"
        ],
        "continuous": true
      },
      "android": {
        "dependsOn": [
          "prepare",
          "^prepare"
        ],
        "inputs": [
          "default",
          "^production"
        ],
        "continuous": true
      },
      "ios": {
        "dependsOn": [
          "prepare",
          "^prepare"
        ],
        "inputs": [
          "production",
          "^production"
        ],
        "continuous": true
      },
      "web": {
        "dependsOn": [
          "prepare",
          "^prepare"
        ],
        "inputs": [
          "production",
          "^production"
        ],
        "continuous": true
      },
      "e2e:android": {
        "continuous": true,
        "dependsOn": [
          "prepare",
          "^prepare",
          {
            "projects": "@exactly/server",
            "target": "e2e"
          },
          {
            "projects": "@exactly/e2e",
            "target": "dev"
          },
          "e2e:android:proxy"
        ],
        "inputs": [
          "production",
          "^production"
        ],
        "executor": "nx:run-commands",
        "options": {
          "command": "expo run:android",
          "env": {
            "APP_DOMAIN": "localhost",
            "CHAIN_ID": "31337",
            "EXPO_PUBLIC_ENV": "e2e"
          }
        }
      },
      "e2e:ios": {
        "continuous": true,
        "dependsOn": [
          "prepare",
          "^prepare",
          {
            "projects": "@exactly/server",
            "target": "e2e"
          },
          {
            "projects": "@exactly/e2e",
            "target": "dev"
          }
        ],
        "inputs": [
          "production",
          "^production"
        ],
        "executor": "nx:run-commands",
        "options": {
          "command": "expo run:ios",
          "env": {
            "APP_DOMAIN": "localhost",
            "CHAIN_ID": "31337",
            "EXPO_PUBLIC_ENV": "e2e"
          }
        }
      },
      "e2e:ios:release": {
        "continuous": true,
        "dependsOn": [
          "prepare",
          "^prepare",
          {
            "projects": "@exactly/e2e",
            "target": "dev"
          }
        ],
        "inputs": [
          "production",
          "^production"
        ],
        "executor": "nx:run-commands",
        "options": {
          "commands": [
            "rm -rf build/Exa.app build/Exa.tar.gz",
            "pnpx eas-cli build --platform=ios --profile=e2e:local --local --output=build/Exa.tar.gz",
            "open -a Simulator",
            "tar -xzf build/Exa.tar.gz -C build",
            "xcrun simctl install booted build/Exa.app"
          ],
          "parallel": false
        }
      },
      "e2e:web": {
        "continuous": true,
        "dependsOn": [
          "prepare",
          "^prepare",
          {
            "projects": "@exactly/server",
            "target": "e2e"
          },
          {
            "projects": "@exactly/e2e",
            "target": "dev"
          }
        ],
        "inputs": [
          "production",
          "^production"
        ],
        "executor": "nx:run-commands",
        "options": {
          "command": "expo start",
          "env": {
            "APP_DOMAIN": "localhost",
            "CHAIN_ID": "31337",
            "EXPO_PUBLIC_ENV": "e2e"
          }
        }
      },
      "test": {
        "dependsOn": [
          "test:spell",
          "test:deps",
          "test:build",
          "test:ts",
          "test:markdown",
          "test:changeset",
          "test:eslint"
        ],
        "executor": "nx:noop"
      }
    }
  },
  "private": true
}
