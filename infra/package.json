    "eslint": "catalog:",
    "eslint-config-universe": "^15.0.3",
    "typescript": "catalog:"
  },
  "nx": {
    "projectType": "application",
    "targets": {
      "test": {
        "dependsOn": [
          "test:eslint",
          "test:ts"
        ],
        "executor": "nx:noop"
